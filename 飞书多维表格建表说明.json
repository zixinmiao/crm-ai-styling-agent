        {"name": "风格标签", "type": "multi_select"},
        {"name": "场景标签", "type": "multi_select"},
        {"name": "适合身形标签", "type": "multi_select"},
        {"name": "色彩关系", "type": "text"},
        {"name": "层次结构", "type": "text"},
        {"name": "搭配逻辑", "type": "text"},
        {"name": "推荐理由", "type": "text"},
