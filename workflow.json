{
  "schema_version": "1.0.0",
  "scene": {
    "id": "scene-styling-recommendation",
    "name": "商品搭配与试衣候选场景",
    "description": "基于商品知识库、门店库存、穿搭图片和吊牌图，为导购生成店内可执行的搭配候选。",
    "trigger": "事件监听",
    "collaboration_mode": "supervisor",
    "chain_mode": "sequence"
  },
  "orchestration": {
    "id": "orch-agent-lobster-styling",
    "name": "导购穿搭 Agent 内部编排",
    "type": "agent_internal",
    "version": "v0.1",
    "status": "draft"
  },
  "nodes": [
    {
      "id": "intake",
      "name": "接收输入",
      "type": "trigger",
      "skill": "skill-styling-intake-router",
      "description": "识别当前输入是库存数据、穿搭图片、吊牌图还是试衣候选请求。"
    },
    {
      "id": "inventory_normalize",
      "name": "库存商品标准化",
      "type": "skill",
      "skill": "skill-styling-inventory-normalize",
      "description": "把门店库存映射为可检索的商品知识结构。"
    },
    {
      "id": "look_parse",
      "name": "穿搭图片拆解",
      "type": "skill",
      "skill": "skill-styling-look-parse",
      "description": "拆解穿搭图片中的商品组成、风格、色彩和身形适配。"
    },
    {
      "id": "tag_recognize",
      "name": "吊牌识别与商品匹配",
      "type": "skill",
      "skill": "skill-styling-tag-recognize",
      "description": "OCR 吊牌款号，按款号优先精确命中商品知识库，并联查门店库存状态；无法确认时走人工兜底。"
    },
    {
      "id": "customer_profile",
      "name": "顾客画像与身形解析",
      "type": "skill",
      "skill": "skill-styling-customer-profile-parse",
      "description": "从导购文字、顾客偏好和试衣场景中提取身形、风格偏好、场景偏好和推荐约束。"
    },
    {
      "id": "knowledge_sync",
      "name": "知识库沉淀",
      "type": "data",
      "skill": "skill-styling-knowledge-sync",
      "description": "把商品知识卡与搭配知识卡写入知识库载体。"
    },
    {
      "id": "outfit_recommend",
      "name": "试衣候选推荐",
      "type": "skill",
      "skill": "skill-styling-outfit-recommend",
      "description": "基于单品、库存、风格和身形生成 3-5 套可执行搭配。"
    },
    {
      "id": "sales_script",
      "name": "导购推荐话术",
      "type": "skill",
      "skill": "skill-styling-sales-script-generate",
      "description": "把搭配候选转成导购可直接说的话术。"
    }
  ],
  "edges": [
    {"source": "intake", "target": "inventory_normalize", "relation": "conditional"},
    {"source": "intake", "target": "look_parse", "relation": "conditional"},
    {"source": "intake", "target": "tag_recognize", "relation": "conditional"},
    {"source": "intake", "target": "customer_profile", "relation": "conditional"},
    {"source": "inventory_normalize", "target": "knowledge_sync", "relation": "next"},
    {"source": "look_parse", "target": "knowledge_sync", "relation": "next"},
    {"source": "tag_recognize", "target": "outfit_recommend", "relation": "next"},
    {"source": "customer_profile", "target": "outfit_recommend", "relation": "next"},
    {"source": "knowledge_sync", "target": "outfit_recommend", "relation": "async_reference"},
    {"source": "outfit_recommend", "target": "sales_script", "relation": "next"}
  ]
}
