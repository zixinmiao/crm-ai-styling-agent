    {
      "name": "商品知识库",
      "desc": "承接品牌 PDF 商品资料解析结果",
      "fields": [
        {"name": "商品ID", "type": "text"},
        {"name": "品牌", "type": "text"},
        {"name": "季节", "type": "single_select"},
        {"name": "系列", "type": "text"},
        {"name": "款号", "type": "text"},
        {"name": "商品名", "type": "text"},
        {"name": "品类", "type": "single_select"},
        {"name": "性别线", "type": "single_select"},
        {"name": "颜色", "type": "multi_select"},
        {"name": "材质", "type": "multi_select"},
        {"name": "版型", "type": "single_select"},
        {"name": "长度标签", "type": "single_select"},
        {"name": "风格标签", "type": "multi_select"},
