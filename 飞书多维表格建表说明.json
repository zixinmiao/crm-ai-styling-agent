        {"name": "来源图片", "type": "url"},
        {"name": "是否可推荐", "type": "checkbox"}
      ]
    },
    {
      "name": "门店模拟库存库",
      "desc": "第一版模拟库存，支撑试衣候选推荐",
      "fields": [
        {"name": "库存ID", "type": "text"},
        {"name": "门店", "type": "single_select"},
        {"name": "商品ID", "type": "text"},
        {"name": "款号", "type": "text"},
        {"name": "商品名", "type": "text"},
        {"name": "品类", "type": "single_select"},
        {"name": "颜色", "type": "single_select"},
        {"name": "尺码", "type": "single_select"},
        {"name": "库存数量", "type": "number"},
        {"name": "在库状态", "type": "single_select"},
